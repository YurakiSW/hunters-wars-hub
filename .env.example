# Upstash Redis (stesso servizio già usato per SW Auto Redeemer — puoi
# creare un nuovo database Upstash separato per questo progetto, o riusare
# lo stesso account Upstash con un DB diverso).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Chiave segreta per firmare le sessioni di login (JWT). Genera una stringa
# lunga e casuale, es. con: openssl rand -base64 32
SESSION_SECRET=

# Chiave segreta condivisa per autorizzare la chiamata di sync mostri da
# cron-job.org (stesso principio usato per il redeemer). Genera anche
# questa con una stringa casuale.
CRON_SECRET=
